TELEGRAM_BOT_TOKEN=replace_me
DB_PATH=stats.db
AI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_DEFAULT_COUNT=3
AI_MAX_SOURCE_CHARS=4000
AI_OFFLINE_FALLBACK=true
PRESERVE_TARGET_ORDER=true
GROUP_AUTO_PARSE_MCQS=true
AI_BACKEND_FAILURE_COOLDOWN=300
DELETE_SOURCE_MESSAGES=false
QUIZ_CONFIRMATION_MESSAGE=true
ENABLE_WEB_PREVIEW=true
PUBLIC_BASE_URL=https://your-app-domain.com
TELEGRAM_BOT_USERNAME=your_bot_username
CONCURRENT_UPDATES=64
GLOBAL_SEND_LIMIT=100
LONG_POLL_TIMEOUT=30
MAX_QUEUE_SIZE=2500
MAX_MCQ_BLOCK_LINES=240
MAX_CONCURRENT_SEND=8
SEND_INTERVAL=0.15
FAST_SEND_INTERVAL=0.03

# Free local Ollama example:
# OPENAI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:14b-instruct

# If no AI endpoint is configured, the bot can still use its offline
# study fallback engine for quizzes and lightweight study tools.

# If your platform exposes a public domain automatically, you can leave
# PUBLIC_BASE_URL empty and let the bot try the Railway / Render / Vercel
# environment variables first.
